{
  "$defs": {
    "AppEntry": {
      "additionalProperties": false,
      "description": "A single Prowlarr application connection (D-03-03).\n\nEncodes the declarative YAML model: one entry per Sonarr/Radarr instance\nthat Prowlarr should sync to. The reconciler (Plan 05) resolves\n``api_key_env`` via ``os.environ`` at runtime \u2014 the API key value itself\nNEVER appears in this YAML.",
      "properties": {
        "api_key_env": {
          "description": "Name of the environment variable holding the target's API key.",
          "title": "Api Key Env",
          "type": "string"
        },
        "base_url": {
          "description": "HTTP URL Prowlarr uses to reach the target (e.g. http://sonarr.svc:8989).",
          "title": "Base Url",
          "type": "string"
        },
        "name": {
          "description": "Display name of the connection in Prowlarr (match key, D-03-03).",
          "title": "Name",
          "type": "string"
        },
        "sync_level": {
          "default": "fullSync",
          "description": "Prowlarr syncLevel (mirror of the field in /api/v1/applications).",
          "enum": [
            "fullSync",
            "addOnly",
            "disabled"
          ],
          "title": "Sync Level",
          "type": "string"
        },
        "type": {
          "description": "Target *arr family member type.",
          "enum": [
            "sonarr",
            "radarr"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "type",
        "base_url",
        "api_key_env"
      ],
      "title": "AppEntry",
      "type": "object"
    },
    "AppsSection": {
      "additionalProperties": false,
      "description": "Prowlarr app-sync section (D-03-02 \u2014 only resource type Prowlarr reconciles).",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/AppEntry"
          },
          "title": "Items",
          "type": "array"
        },
        "prune": {
          "default": false,
          "description": "Opt-in prune (D-04).",
          "title": "Prune",
          "type": "boolean"
        }
      },
      "title": "AppsSection",
      "type": "object"
    },
    "DownloadClient": {
      "additionalProperties": true,
      "description": "A Sonarr download client (qBittorrent, Transmission, ...).\n\nMatched by ``name`` (D-20). Read-only fields excluded from diff (D-21).\nUses ``extra=\"allow\"`` for forward-compat with future Sonarr versions\n(Phase 1 simplification \u2014 Pitfall 4 trade-off documented in RESEARCH.md).",
      "properties": {
        "configContract": {
          "description": "Sonarr config contract (e.g., 'QBittorrentSettings'). Must match implementation.",
          "title": "Configcontract",
          "type": "string"
        },
        "enable": {
          "default": true,
          "description": "Enable this download client.",
          "title": "Enable",
          "type": "boolean"
        },
        "fields": {
          "description": "Implementation-specific settings (host, port, category, ...).",
          "items": {
            "$ref": "#/$defs/FieldKV"
          },
          "title": "Fields",
          "type": "array"
        },
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "implementation": {
          "description": "Sonarr implementation class (e.g., 'QBittorrent', 'Transmission').",
          "title": "Implementation",
          "type": "string"
        },
        "implementationName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Implementationname"
        },
        "infoLink": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Infolink"
        },
        "message": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "name": {
          "description": "Display name (matching key, must be unique).",
          "title": "Name",
          "type": "string"
        },
        "presets": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Presets"
        },
        "priority": {
          "default": 1,
          "description": "Lower = preferred when multiple clients match.",
          "title": "Priority",
          "type": "integer"
        },
        "protocol": {
          "description": "Download protocol \u2014 must match implementation.",
          "enum": [
            "torrent",
            "usenet"
          ],
          "title": "Protocol",
          "type": "string"
        },
        "removeCompletedDownloads": {
          "default": true,
          "title": "Removecompleteddownloads",
          "type": "boolean"
        },
        "removeFailedDownloads": {
          "default": true,
          "title": "Removefaileddownloads",
          "type": "boolean"
        },
        "tags": {
          "description": "Tag IDs (resolved from `tags:` names by reconciler).",
          "items": {
            "type": "integer"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "name",
        "protocol",
        "implementation",
        "configContract"
      ],
      "title": "DownloadClient",
      "type": "object"
    },
    "DownloadClientsSection": {
      "additionalProperties": false,
      "description": "A list of download_clients with opt-in prune (D-04).",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/DownloadClient"
          },
          "title": "Items",
          "type": "array"
        },
        "prune": {
          "default": false,
          "description": "Opt-in deletion of unmanaged resources (D-04).",
          "title": "Prune",
          "type": "boolean"
        }
      },
      "title": "DownloadClientsSection",
      "type": "object"
    },
    "FieldKV": {
      "additionalProperties": true,
      "description": "Generic key-value used in Sonarr's ``fields[]`` array (qBit-specific settings).\n\nSource: Sonarr OpenAPI #/components/schemas/Field. Sonarr ad-hoc adds\nUI-metadata keys (``label``, ``helpText``, ``selectOptions``...) so we\naccept ``extra=\"allow\"`` and exclude these from diffs (Pitfall 2).",
      "properties": {
        "advanced": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Advanced"
        },
        "helpText": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Helptext"
        },
        "isFloat": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Isfloat"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "name": {
          "description": "Field name (e.g., 'host', 'port', 'tvCategory').",
          "title": "Name",
          "type": "string"
        },
        "order": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Order"
        },
        "privacy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Privacy"
        },
        "selectOptions": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selectoptions"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Type"
        },
        "value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Field value \u2014 type depends on field name.",
          "title": "Value"
        }
      },
      "required": [
        "name"
      ],
      "title": "FieldKV",
      "type": "object"
    },
    "HostConfigSection": {
      "additionalProperties": false,
      "description": "Opt-in host_config reconciliation (D-03-04).\n\n``enable`` defaults to ``False`` \u2014 the reconciler logs ``host_config_reconcile_skipped``\nand returns without calling GET /config/host. This prevents an accidental\nYAML typo from locking arrconf out of the app via authenticationRequired\nmisconfiguration. To activate host_config reconciliation, set\n``host_config: { enable: true }`` explicitly in the YAML config.\n\nOnly the safe-to-reconcile subset of host_config fields is modeled \u2014 the\nfull HostConfig model (Plan 01) has more fields but they are either\nserver-derived or credential-sensitive (apiKey / password) and excluded\nwith ``exclude=True`` on the resource model.",
      "properties": {
        "authenticationMethod": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Sonarr/Radarr authentication method (e.g. 'forms', 'basic', 'none').",
          "title": "Authenticationmethod"
        },
        "authenticationRequired": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Sonarr/Radarr auth requirement (e.g. 'enabled', 'disabledForLocalAddresses').",
          "title": "Authenticationrequired"
        },
        "enable": {
          "default": false,
          "description": "Opt-in flag \u2014 host_config reconcile is skipped unless this is True (D-03-04).",
          "title": "Enable",
          "type": "boolean"
        },
        "instanceName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Display name of the instance.",
          "title": "Instancename"
        },
        "urlBase": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URL base path (e.g. '/sonarr').",
          "title": "Urlbase"
        }
      },
      "title": "HostConfigSection",
      "type": "object"
    },
    "Indexer": {
      "additionalProperties": true,
      "description": "A Sonarr/Radarr indexer entry (created by Prowlarr sync, not by arrconf directly).\n\nPhase 3 reconciles indexers for sync alignment only (D-03-02: arrconf does\nnot manage indexer definitions \u2014 Prowlarr does). The standard diff/PUT\npattern still applies: cluster state is compared against YAML desired\nstate, with WR-01 credential safety on the apiKey field.",
      "properties": {
        "configContract": {
          "description": "Sonarr/Radarr config contract.",
          "title": "Configcontract",
          "type": "string"
        },
        "downloadClientId": {
          "default": 0,
          "title": "Downloadclientid",
          "type": "integer"
        },
        "enable": {
          "default": true,
          "title": "Enable",
          "type": "boolean"
        },
        "enableAutomaticSearch": {
          "default": true,
          "title": "Enableautomaticsearch",
          "type": "boolean"
        },
        "enableInteractiveSearch": {
          "default": true,
          "title": "Enableinteractivesearch",
          "type": "boolean"
        },
        "enableRss": {
          "default": true,
          "title": "Enablerss",
          "type": "boolean"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/FieldKV"
          },
          "title": "Fields",
          "type": "array"
        },
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "implementation": {
          "description": "Sonarr/Radarr implementation class.",
          "title": "Implementation",
          "type": "string"
        },
        "implementationName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Implementationname"
        },
        "infoLink": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Infolink"
        },
        "name": {
          "description": "Display name (matching key, must be unique).",
          "title": "Name",
          "type": "string"
        },
        "priority": {
          "default": 25,
          "title": "Priority",
          "type": "integer"
        },
        "tags": {
          "items": {
            "type": "integer"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "name",
        "implementation",
        "configContract"
      ],
      "title": "Indexer",
      "type": "object"
    },
    "IndexersSection": {
      "additionalProperties": false,
      "description": "A list of indexers with opt-in prune (D-04).",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/Indexer"
          },
          "title": "Items",
          "type": "array"
        },
        "prune": {
          "default": false,
          "description": "Opt-in prune (D-04).",
          "title": "Prune",
          "type": "boolean"
        }
      },
      "title": "IndexersSection",
      "type": "object"
    },
    "Notification": {
      "additionalProperties": true,
      "description": "A Sonarr/Radarr notification entry (Discord, Slack, webhook, custom script, ...).\n\nMatched by ``name`` (D-20). ``on*`` event flags differ between Sonarr and\nRadarr \u2014 captured via extra=\"allow\" so the same Notification class works\nfor both apps without app-specific subclassing.",
      "properties": {
        "configContract": {
          "title": "Configcontract",
          "type": "string"
        },
        "enable": {
          "default": true,
          "title": "Enable",
          "type": "boolean"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/FieldKV"
          },
          "title": "Fields",
          "type": "array"
        },
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "implementation": {
          "title": "Implementation",
          "type": "string"
        },
        "implementationName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Implementationname"
        },
        "includeHealthWarnings": {
          "default": false,
          "title": "Includehealthwarnings",
          "type": "boolean"
        },
        "infoLink": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Infolink"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "integer"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "name",
        "implementation",
        "configContract"
      ],
      "title": "Notification",
      "type": "object"
    },
    "NotificationsSection": {
      "additionalProperties": false,
      "description": "A list of notifications with opt-in prune (D-04).",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/Notification"
          },
          "title": "Items",
          "type": "array"
        },
        "prune": {
          "default": false,
          "description": "Opt-in prune (D-04).",
          "title": "Prune",
          "type": "boolean"
        }
      },
      "title": "NotificationsSection",
      "type": "object"
    },
    "ProwlarrInstance": {
      "additionalProperties": false,
      "description": "A single Prowlarr instance (Phase 3, D-03-02 \u2014 app sync only).\n\nIndexer definitions (the catalog of newsnab / torznab endpoints) remain\nmanaged in the Prowlarr UI \u2014 they are out of Phase 3 scope.",
      "properties": {
        "apps": {
          "$ref": "#/$defs/AppsSection"
        },
        "base_url": {
          "description": "Prowlarr base URL e.g. http://prowlarr.svc:9696",
          "title": "Base Url",
          "type": "string"
        }
      },
      "required": [
        "base_url"
      ],
      "title": "ProwlarrInstance",
      "type": "object"
    },
    "RadarrInstance": {
      "additionalProperties": false,
      "description": "A single Radarr instance (Phase 3, D-03-01 \u2014 full parity with SonarrInstance).\n\nIdentical section list to SonarrInstance \u2014 Radarr's v3 API exposes the\nsame resource types with the same shapes. The reconciler (Plan 04) is a\nparallel implementation; the YAML schema is intentionally aligned.",
      "properties": {
        "base_url": {
          "description": "Radarr base URL e.g. http://radarr.svc:7878",
          "title": "Base Url",
          "type": "string"
        },
        "download_clients": {
          "$ref": "#/$defs/DownloadClientsSection"
        },
        "host_config": {
          "$ref": "#/$defs/HostConfigSection"
        },
        "indexers": {
          "$ref": "#/$defs/IndexersSection"
        },
        "notifications": {
          "$ref": "#/$defs/NotificationsSection"
        },
        "root_folders": {
          "$ref": "#/$defs/RootFoldersSection"
        }
      },
      "required": [
        "base_url"
      ],
      "title": "RadarrInstance",
      "type": "object"
    },
    "RootFolder": {
      "additionalProperties": true,
      "description": "A Sonarr/Radarr root folder. ``path`` is the stable identity (D-03-01).",
      "properties": {
        "accessible": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accessible"
        },
        "freeSpace": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Freespace"
        },
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "path": {
          "description": "Filesystem path (match key for reconcile()).",
          "title": "Path",
          "type": "string"
        },
        "unmappedFolders": {
          "anyOf": [
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unmappedfolders"
        }
      },
      "required": [
        "path"
      ],
      "title": "RootFolder",
      "type": "object"
    },
    "RootFoldersSection": {
      "additionalProperties": false,
      "description": "A list of root folders with opt-in prune (D-04).\n\nSonarr/Radarr have NO PUT endpoint for root folders \u2014 path changes produce\nDELETE + ADD via the differ (RESEARCH.md Pitfall 1).",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/RootFolder"
          },
          "title": "Items",
          "type": "array"
        },
        "prune": {
          "default": false,
          "description": "Opt-in prune (D-04).",
          "title": "Prune",
          "type": "boolean"
        }
      },
      "title": "RootFoldersSection",
      "type": "object"
    },
    "SonarrInstance": {
      "additionalProperties": false,
      "description": "A single Sonarr instance (Phase 3 extends Phase 1's download_clients-only scope).\n\nResource section order is alphabetical for readability \u2014 runtime\nreconcile ordering is enforced by the reconciler itself (Plan 03).",
      "properties": {
        "base_url": {
          "description": "Sonarr base URL e.g. http://sonarr.svc:8989",
          "title": "Base Url",
          "type": "string"
        },
        "download_clients": {
          "$ref": "#/$defs/DownloadClientsSection"
        },
        "host_config": {
          "$ref": "#/$defs/HostConfigSection"
        },
        "indexers": {
          "$ref": "#/$defs/IndexersSection"
        },
        "notifications": {
          "$ref": "#/$defs/NotificationsSection"
        },
        "root_folders": {
          "$ref": "#/$defs/RootFoldersSection"
        }
      },
      "required": [
        "base_url"
      ],
      "title": "SonarrInstance",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Top-level arrconf YAML schema (root for JSON Schema generation).\n\nPhase 3 (D-03-05): flat ``sonarr`` / ``radarr`` / ``prowlarr`` dicts at the\nroot level. The Phase-1 ``apps:`` indirection has been removed \u2014 every\ncaller updated atomically with this rewrite (Plan 02 Task 2.3).",
  "properties": {
    "prowlarr": {
      "additionalProperties": {
        "$ref": "#/$defs/ProwlarrInstance"
      },
      "title": "Prowlarr",
      "type": "object"
    },
    "radarr": {
      "additionalProperties": {
        "$ref": "#/$defs/RadarrInstance"
      },
      "title": "Radarr",
      "type": "object"
    },
    "sonarr": {
      "additionalProperties": {
        "$ref": "#/$defs/SonarrInstance"
      },
      "title": "Sonarr",
      "type": "object"
    }
  },
  "title": "RootConfig",
  "type": "object"
}

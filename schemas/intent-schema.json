{
  "$defs": {
    "Category": {
      "additionalProperties": false,
      "description": "A single Category \u2014 declarative input for Phase 10's 6-app propagation.\n\nMatch key: ``name`` (kebab-case slug, stable across reconcile runs).\nD-04 invariant: ``base_path`` MUST equal ``f\"/media/{name}\"``.",
      "properties": {
        "base_path": {
          "description": "Absolute path under /media \u2014 MUST be /media/{name} (D-04).",
          "title": "Base Path",
          "type": "string"
        },
        "display": {
          "description": "Title Case human label (e.g. 'S\u00e9ries - \u00c9milie').",
          "title": "Display",
          "type": "string"
        },
        "kind": {
          "description": "Media kind \u2014 drives Sonarr vs Radarr propagation.",
          "enum": [
            "movies",
            "series"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "description": "Kebab-case slug (e.g. 'series-emilie'). Stable match key.",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "title": "Name",
          "type": "string"
        },
        "profile": {
          "description": "Quality profile group \u2014 drives configarr profile selection (Phase 10) and Seerr animeTags routing for profile=anime.",
          "enum": [
            "general",
            "anime",
            "family"
          ],
          "title": "Profile",
          "type": "string"
        }
      },
      "required": [
        "name",
        "kind",
        "profile",
        "display",
        "base_path"
      ],
      "title": "Category",
      "type": "object"
    },
    "CrossSeedConfig": {
      "additionalProperties": false,
      "description": "Configuration block for the cross-seed tool (XSEED, INTENT-01).",
      "properties": {
        "action": {
          "default": "inject",
          "description": "inject|save.",
          "title": "Action",
          "type": "string"
        },
        "link_dirs": {
          "description": "Hardlink destination dirs.",
          "items": {
            "type": "string"
          },
          "title": "Link Dirs",
          "type": "array"
        },
        "link_type": {
          "default": "hardlink",
          "description": "symlink|hardlink|reflink.",
          "title": "Link Type",
          "type": "string"
        },
        "torrent_clients": {
          "description": "Client connection strings (e.g. qbittorrent:http://user:pass@host:port).",
          "items": {
            "type": "string"
          },
          "title": "Torrent Clients",
          "type": "array"
        },
        "torznab": {
          "description": "List of torznab URLs (Prowlarr: http://host/N/api?apikey=KEY).",
          "items": {
            "type": "string"
          },
          "title": "Torznab",
          "type": "array"
        }
      },
      "title": "CrossSeedConfig",
      "type": "object"
    },
    "QbitManageConfig": {
      "additionalProperties": false,
      "description": "tools.qbit_manage block in intent.yml (QBM-01).",
      "properties": {
        "qbt_host": {
          "default": "http://qbittorrent.selfhost.svc.cluster.local:8080",
          "description": "qBittorrent WebUI URL (in-cluster).",
          "title": "Qbt Host",
          "type": "string"
        },
        "recyclebin_days": {
          "default": 30,
          "description": "Days before recyclebin is purged (D-05).",
          "title": "Recyclebin Days",
          "type": "integer"
        },
        "rem_orphaned": {
          "default": false,
          "description": "Remove orphaned files (D-04 opt-in).",
          "title": "Rem Orphaned",
          "type": "boolean"
        },
        "rem_unregistered": {
          "default": false,
          "description": "Remove unregistered torrents (D-04 opt-in).",
          "title": "Rem Unregistered",
          "type": "boolean"
        },
        "share_limits": {
          "description": "Per-tracker share limit groups (D-01/D-02).",
          "items": {
            "$ref": "#/$defs/ShareLimitGroup"
          },
          "title": "Share Limits",
          "type": "array"
        },
        "tracker_tags": {
          "description": "Per-tracker tag rules.",
          "items": {
            "$ref": "#/$defs/TrackerTagEntry"
          },
          "title": "Tracker Tags",
          "type": "array"
        }
      },
      "title": "QbitManageConfig",
      "type": "object"
    },
    "SagaEntry": {
      "additionalProperties": false,
      "description": "A single saga declaration (Phase 29 locked schema \u2014 D-02).\n\nkind=movies: tmdb_collection REQUIRED; profile + root REQUIRED; items ignored.\nkind=series: items OPTIONAL (titles of member series); profile/root/tmdb_collection not used.",
      "properties": {
        "items": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Series titles for Jellyfin BoxSet membership. kind=series only.",
          "title": "Items"
        },
        "kind": {
          "description": "Discriminator.",
          "enum": [
            "movies",
            "series"
          ],
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "description": "Saga display name; also the Jellyfin BoxSet name for series.",
          "title": "Name",
          "type": "string"
        },
        "profile": {
          "default": "",
          "description": "Radarr quality profile name. Required when kind=movies.",
          "title": "Profile",
          "type": "string"
        },
        "root": {
          "default": "",
          "description": "Radarr root folder path. Required when kind=movies.",
          "title": "Root",
          "type": "string"
        },
        "tmdb_collection": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "TMDB collection id. Required when kind=movies.",
          "title": "Tmdb Collection"
        }
      },
      "required": [
        "name",
        "kind"
      ],
      "title": "SagaEntry",
      "type": "object"
    },
    "ShareLimitGroup": {
      "additionalProperties": false,
      "description": "One share_limits group (D-02).",
      "properties": {
        "cleanup": {
          "default": false,
          "description": "Delete on limit reached (to recyclebin).",
          "title": "Cleanup",
          "type": "boolean"
        },
        "max_ratio": {
          "default": -1.0,
          "description": "-1 = disabled.",
          "title": "Max Ratio",
          "type": "number"
        },
        "max_seeding_time": {
          "default": -1,
          "description": "Minutes. -1 = disabled.",
          "title": "Max Seeding Time",
          "type": "integer"
        },
        "min_seeding_time": {
          "default": 0,
          "description": "Minutes.",
          "title": "Min Seeding Time",
          "type": "integer"
        },
        "name": {
          "description": "Group name (also used as qbit_manage group key).",
          "title": "Name",
          "type": "string"
        },
        "priority": {
          "description": "Lower = higher priority.",
          "title": "Priority",
          "type": "integer"
        },
        "tracker_tag": {
          "description": "Tracker tag to match (include_all_tags filter).",
          "title": "Tracker Tag",
          "type": "string"
        }
      },
      "required": [
        "name",
        "tracker_tag",
        "priority"
      ],
      "title": "ShareLimitGroup",
      "type": "object"
    },
    "ToolsConfig": {
      "additionalProperties": false,
      "description": "Absorbed external tools (cross_seed, qbit_manage).",
      "properties": {
        "cross_seed": {
          "anyOf": [
            {
              "$ref": "#/$defs/CrossSeedConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "cross-seed block (XSEED). None when unconfigured."
        },
        "qbit_manage": {
          "anyOf": [
            {
              "$ref": "#/$defs/QbitManageConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "qbit_manage block (QBM-01). None when unconfigured."
        }
      },
      "title": "ToolsConfig",
      "type": "object"
    },
    "TrackerTagEntry": {
      "additionalProperties": false,
      "description": "One tracker_tags entry.",
      "properties": {
        "keyword": {
          "description": "Tracker URL keyword (partial match).",
          "title": "Keyword",
          "type": "string"
        },
        "tag": {
          "description": "Tag to apply to matching torrents.",
          "title": "Tag",
          "type": "string"
        }
      },
      "required": [
        "keyword",
        "tag"
      ],
      "title": "TrackerTagEntry",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Root schema for intent.yml (INTENT-01, Phase 28).\n\nTop-level layout: ``tools:`` mapping + ``sagas:`` list + ``categories:`` list + ``apps:`` dict.\nPhase 32 (CATMIG-01 / D-32-01): ``categories`` and ``apps`` absorbed from arrconf.yml.\n``categories`` is now the single hand-edited owner of the media category list.\n``apps`` is an untyped pass-through dict emitted verbatim into generated arrconf.yml.",
  "properties": {
    "apps": {
      "additionalProperties": true,
      "description": "App config pass-through (sonarr/radarr/prowlarr/qbittorrent/seerr/jellyfin). Emitted verbatim into generated arrconf.yml \u2014 no pydantic validation (D-32-01 YAGNI).",
      "title": "Apps",
      "type": "object"
    },
    "categories": {
      "description": "Cross-cutting media categories (lifted from arrconf.yml, D-32-01).",
      "items": {
        "$ref": "#/$defs/Category"
      },
      "title": "Categories",
      "type": "array"
    },
    "sagas": {
      "description": "Saga declarations. Schema present-but-unexercised in P28 (D-05).",
      "items": {
        "$ref": "#/$defs/SagaEntry"
      },
      "title": "Sagas",
      "type": "array"
    },
    "tools": {
      "$ref": "#/$defs/ToolsConfig"
    }
  },
  "title": "IntentConfig",
  "type": "object"
}

# arr-stack — env vars template for snapshot.sh and arrconf
#
# Usage:
#   cp .env.example .env        # .env est gitignored (ne jamais committer .env)
#   $EDITOR .env                # remplir les valeurs <REMPLACER>
#   set -a; source .env; set +a # charger en mémoire dans le shell courant
#
# Convention CLAUDE.md : aucune lecture de fichier de secrets dans le code.
# .env est un confort de DEV uniquement. En cluster, K8s injecte tout via
# `envFrom: secretRef` (cf bootstrap secrets dans my-kluster/secrets/).

# ─────────────────────────────────────────────────────────────────────────
# URLs des apps (optionnel — défauts localhost:port si tu utilises
# `kubectl port-forward`. À surcharger si tu accèdes via Tailscale, ingress
# direct, ou tunnel SSH.)
# ─────────────────────────────────────────────────────────────────────────

# SONARR_URL=http://localhost:8989
# RADARR_URL=http://localhost:7878
# PROWLARR_URL=http://localhost:9696
# QBT_URL=http://localhost:8080
# SEERR_URL=http://localhost:5055
# JELLYFIN_URL=http://localhost:8096

# ─────────────────────────────────────────────────────────────────────────
# Credentials des apps (REQUIS — 7 variables à renseigner)
#
# Source de vérité actuelle : my-kluster/secrets/configarr-secret.yaml
# (les API keys *arr existent déjà ; les autres sont à générer via UI une
# première fois — cf REQ-bootstrap-exception, NG5).
# ─────────────────────────────────────────────────────────────────────────

# Sonarr — header X-Api-Key
# Source : my-kluster/secrets/configarr-secret.yaml (clé `SONARR_API_KEY`)
# OU UI Sonarr → Settings → General → Security → API Key
SONARR_API_KEY=<REMPLACER>

# Radarr — header X-Api-Key
# Source : my-kluster/secrets/configarr-secret.yaml (clé `RADARR_API_KEY`)
# OU UI Radarr → Settings → General → Security → API Key
RADARR_API_KEY=<REMPLACER>

# Prowlarr — header X-Api-Key
# Source : UI Prowlarr → Settings → General → Security → API Key
# (à générer si pas encore fait — d'où l'assumption A2 du researcher)
PROWLARR_API_KEY=<REMPLACER>

# qBittorrent — auth cookie via login form (pas d'API key)
# Source : credentials admin de l'instance qBittorrent (UI Tools → Options
# → Web UI → Authentication ; password est hashé côté serveur)
QBT_USER=admin
QBT_PASS=<REMPLACER>

# Seerr (Jellyseerr ou Overseerr) — header X-Api-Key
# Source : UI Seerr → Settings → General → API Key
SEERR_API_KEY=<REMPLACER>

# Jellyfin — header `Authorization: MediaBrowser Token="..."`
# Source : UI Jellyfin → Dashboard → API Keys → New API Key
# (l'instance doit avoir un compte admin bootstrap — assumption A3 ;
# si pas fait, le snapshot Jellyfin sera partiel mais la phase tolère ce cas)
JELLYFIN_API_KEY=<REMPLACER>

# ─────────────────────────────────────────────────────────────────────────
# Variables internes arrconf (Phase 1+) — pas requises pour Phase 0
# ─────────────────────────────────────────────────────────────────────────

# ARRCONF_LOG_LEVEL=INFO
# ARRCONF_DRY_RUN=false
